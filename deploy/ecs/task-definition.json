{
  "family": "ticketing-web",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "ticketing-web",
      "image": "${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}",
      "cpu": 512,
      "memory": 1024,
      "memoryReservation": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 0,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "APP_DEBUG", "value": "false" },
        { "name": "LOG_CHANNEL", "value": "stack" },
        { "name": "LOG_STACK", "value": "stderr" },
        { "name": "LOG_LEVEL", "value": "warning" },
        { "name": "CACHE_STORE", "value": "redis" },
        { "name": "SESSION_DRIVER", "value": "redis" },
        { "name": "QUEUE_CONNECTION", "value": "sqs" },
        { "name": "FILESYSTEM_DISK", "value": "s3" },
        { "name": "MAIL_MAILER", "value": "ses" },
        { "name": "SESSION_SECURE_COOKIE", "value": "true" },
        { "name": "TRUSTED_PROXIES", "value": "*" },
        { "name": "ENABLE_QUEUE_WORKER", "value": "false" },
        { "name": "ENABLE_SCHEDULER", "value": "false" }
      ],
      "secrets": [
        { "name": "APP_KEY", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/APP_KEY" },
        { "name": "DB_HOST", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/DB_HOST" },
        { "name": "DB_DATABASE", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/DB_DATABASE" },
        { "name": "DB_USERNAME", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/DB_USERNAME" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/DB_PASSWORD" },
        { "name": "REDIS_HOST", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/REDIS_HOST" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/AWS_ACCESS_KEY_ID" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/AWS_SECRET_ACCESS_KEY" },
        { "name": "AWS_DEFAULT_REGION", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/AWS_DEFAULT_REGION" },
        { "name": "AWS_BUCKET", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/AWS_BUCKET" },
        { "name": "SQS_PREFIX", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/SQS_PREFIX" },
        { "name": "SQS_QUEUE", "valueFrom": "arn:aws:ssm:REGION:ACCOUNT:parameter/ticketing/SQS_QUEUE" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost/up || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ticketing",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ],
  "requiresCompatibilities": ["EC2"],
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/ecsTaskRole"
}
