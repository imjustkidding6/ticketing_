# =============================================================================
# Production Environment Configuration
# =============================================================================
# This file serves as a reference for ECS task definition environment variables.
# Do NOT commit actual secrets — use AWS SSM Parameter Store or Secrets Manager.
# =============================================================================

APP_NAME=Ticketing
APP_ENV=production
APP_KEY=  # Set via SSM Parameter Store
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# === Logging (stderr for container/CloudWatch) ===
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# === Database (RDS MySQL) ===
DB_CONNECTION=mysql
DB_HOST=  # RDS endpoint
DB_PORT=3306
DB_DATABASE=ticketing
DB_USERNAME=  # Set via SSM
DB_PASSWORD=  # Set via SSM

# === Session (ElastiCache Redis) ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# === Drivers ===
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sqs
CACHE_STORE=redis

# === Redis (ElastiCache) ===
REDIS_CLIENT=phpredis
REDIS_HOST=  # ElastiCache endpoint
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Mail (AWS SES) ===
MAIL_MAILER=ses
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# === AWS ===
AWS_ACCESS_KEY_ID=  # Set via SSM or IAM task role
AWS_SECRET_ACCESS_KEY=  # Set via SSM or IAM task role
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=ticketing-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# === SQS Queue ===
SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
SQS_QUEUE=ticketing-default

# === Trusted Proxies (ALB) ===
TRUSTED_PROXIES=*

VITE_APP_NAME="${APP_NAME}"
